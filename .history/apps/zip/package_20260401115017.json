{
    "name": "@games/zip",
    "version": "1.0.0",
    "description": "Zip maze navigation puzzle - navigate through mazes collecting items and reaching goals",
    "main": "src/index.tsx",
    "type": "module",
    "scripts": {
        "build": "vite build",
        "dev": "vite",
        "lint": "eslint src --ext .ts,.tsx",
        "lint:fix": "eslint src --ext .ts,.tsx --fix",
        "preview": "vite preview",
        "test": "vitest run",
        "test:ui": "vitest --ui",
        "test:watch": "vitest",
        "typecheck": "tsc --noEmit",
        "validate": "pnpm typecheck && pnpm lint && pnpm test",
        "fix": "pnpm lint:fix && pnpm format"
    },
    "dependencies": {
        "react": "^19.2.4",
        "react-dom": "^19.2.4"
    },
    "devDependencies": {
        "@types/react": "^19.2.4",
        "@types/react-dom": "^19.2.4",
        "@typescript-eslint/eslint-plugin": "^8.57.0",
        "@typescript-eslint/parser": "^8.57.0",
        "@vitejs/plugin-react": "^4.3.3",
        "eslint": "^10.0.3",
        "eslint-plugin-react-hooks": "^5.1.0",
        "eslint-plugin-react-refresh": "^0.4.16",
        "prettier": "^3.8.1",
        "typescript": "^5.9.3",
        "vite": "^7.3.1",
        "vitest": "^4.0.18"
    }
}