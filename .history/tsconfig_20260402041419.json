{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["vite/client"],
    "paths": {
      "@/*": ["./src/*"],
      "@/domain/*": ["./src/domain/*"],
      "@/app/*": ["./src/app/*"],
      "@/ui/*": ["./src/ui/*"],
      "@games/ai-framework": ["./packages/ai-framework/src/index.ts"],
      "@games/app-hook-utils": ["./packages/app-hook-utils/src/index.ts"],
      "@games/assets-shared": ["./packages/assets-shared/src/index.ts"],
      "@games/card-deck-core": ["./packages/card-deck-core/src/index.ts"],
      "@games/card-deck-system": ["./packages/card-deck-system/src/index.ts"],
      "@games/common": ["./packages/common/src/index.ts"],
      "@games/crash-logger": ["./packages/crash-logger/src/index.ts"],
      "@games/crash-utils": ["./packages/crash-utils/src/index.ts"],
      "@games/display-contract": ["./packages/display-contract/src/index.ts"],
      "@games/domain-shared": ["./packages/domain-shared/src/index.ts"],
      "@games/haptics": ["./packages/haptics/src/index.ts"],
      "@games/shared-hooks": ["./packages/shared-hooks/src/index.ts"],
      "@games/sound-context": ["./packages/sound-context/src/index.ts"],
      "@games/sprite-contract": ["./packages/sprite-contract/src/index.ts"],
      "@games/stats-utils": ["./packages/stats-utils/src/index.ts"],
      "@games/storage-utils": ["./packages/storage-utils/src/index.ts"],
      "@games/theme-context": ["./packages/theme-context/src/index.ts"],
      "@games/theme-contract": ["./packages/theme-contract/src/index.ts"],
      "@games/ui-utils": ["./packages/ui-utils/src/index.ts"],
      "@games/ui-board-core": ["./packages/ui-board-core/src/index.ts"],
      "@games/ui-dice-system": ["./packages/ui-dice-system/src/index.ts"]
    }
  },
  "include": ["src", "src/vite-env.d.ts"]
}
