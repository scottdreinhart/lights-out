{
  "name": "game-platform",
  "version": "1.0.0",
  "description": "Game Platform Monorepo",
  "type": "module",
  "private": true,
  "license": "PROPRIETARY",
  "author": "Scott Reinhart",
  "packageManager": "pnpm@10.31.0",
  "engines": {
    "node": "24.14.1",
    "npm": "11.9.0",
    "pnpm": "10.31.0"
  },
  "main": "apps/lights-out/electron/main.js",
  "scripts": {
    "start": "pnpm -C apps/lights-out start",
    "dev": "pnpm -C apps/lights-out dev",
    "build": "pnpm -C apps/lights-out build",
    "preview": "pnpm -C apps/lights-out preview",
    "build:preview": "pnpm -C apps/lights-out build:preview",
    "lint": "pnpm -C apps/lights-out lint",
    "lint:fix": "pnpm -C apps/lights-out lint:fix",
    "lint:scope:app": "eslint src/app",
    "lint:scope:domain": "eslint src/domain",
    "lint:scope:ui": "eslint src/ui",
    "lint:scope:infrastructure": "eslint src/infrastructure",
    "lint:scope:electron": "eslint src/electron",
    "lint:scope:wasm": "eslint src/wasm",
    "lint:scope:workers": "eslint src/workers",
    "lint:scope:all": "pnpm lint:scope:app && pnpm lint:scope:domain && pnpm lint:scope:ui && pnpm lint:scope:infrastructure && pnpm lint:scope:electron && pnpm lint:scope:wasm && pnpm lint:scope:workers",
    "lint:type:a11y": "node scripts/lint-segmented.mjs --segment=a11y",
    "lint:type:security": "node scripts/lint-segmented.mjs --segment=security",
    "lint:type:hooks": "node scripts/lint-segmented.mjs --segment=hooks",
    "lint:type:react": "node scripts/lint-segmented.mjs --segment=react",
    "lint:type:boundaries": "node scripts/lint-segmented.mjs --segment=boundaries",
    "lint:type:typescript": "node scripts/lint-segmented.mjs --segment=typescript",
    "lint:type:core": "node scripts/lint-segmented.mjs --segment=core",
    "lint:type:all": "pnpm lint:type:a11y && pnpm lint:type:security && pnpm lint:type:hooks && pnpm lint:type:react && pnpm lint:type:boundaries && pnpm lint:type:typescript && pnpm lint:type:core",
    "lint:deep": "node scripts/lint-segmented.mjs --segment=all --scope=all",
    "lint:filewise:app": "node scripts/lint-filewise.mjs --scope=src/app",
    "lint:filewise:domain": "node scripts/lint-filewise.mjs --scope=src/domain",
    "lint:filewise:ui": "node scripts/lint-filewise.mjs --scope=src/ui",
    "lint:filewise:infrastructure": "node scripts/lint-filewise.mjs --scope=src/infrastructure",
    "lint:filewise:electron": "node scripts/lint-filewise.mjs --scope=src/electron",
    "lint:filewise:wasm": "node scripts/lint-filewise.mjs --scope=src/wasm",
    "lint:filewise:workers": "node scripts/lint-filewise.mjs --scope=src/workers",
    "lint:filewise:all": "pnpm lint:filewise:app && pnpm lint:filewise:domain && pnpm lint:filewise:ui && pnpm lint:filewise:infrastructure && pnpm lint:filewise:electron && pnpm lint:filewise:wasm && pnpm lint:filewise:workers",
    "lint:all": "pnpm lint:scope:all && pnpm lint:type:all",
    "lint:ci:fast": "pnpm lint:filewise:app && pnpm lint:filewise:ui && pnpm typecheck",
    "lint:ci:full": "node scripts/run-quality-gates.mjs --full",
    "quality:fast": "pnpm lint:ci:fast",
    "quality:full": "node scripts/run-quality-gates.mjs --full",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "typecheck": "pnpm -C apps/lights-out typecheck",
    "check": "pnpm -C apps/lights-out check",
    "fix": "pnpm -C apps/lights-out lint:fix",
    "validate": "pnpm -C apps/lights-out validate",
    "clean": "rimraf dist release",
    "clean:node": "rimraf node_modules",
    "clean:all": "rimraf dist release node_modules",
    "reinstall": "pnpm clean:all && pnpm install",
    "prebuild": "pnpm clean",
    "electron:dev": "pnpm -C apps/lights-out electron:dev",
    "electron:build": "pnpm -C apps/lights-out electron:build",
    "electron:build:win": "pnpm -C apps/lights-out electron:build:win",
    "electron:build:linux": "pnpm -C apps/lights-out electron:build:linux",
    "electron:build:mac": "pnpm -C apps/lights-out electron:build:mac",
    "electron:preview": "pnpm -C apps/lights-out electron:preview",
    "cap:init:android": "pnpm -C apps/lights-out cap:init:android",
    "cap:init:ios": "pnpm -C apps/lights-out cap:init:ios",
    "cap:sync": "pnpm -C apps/lights-out cap:sync",
    "cap:open:android": "pnpm -C apps/lights-out cap:open:android",
    "cap:open:ios": "pnpm -C apps/lights-out cap:open:ios",
    "cap:run:android": "pnpm -C apps/lights-out cap:run:android",
    "cap:run:ios": "pnpm -C apps/lights-out cap:run:ios",
    "wasm:build": "pnpm exec node scripts/build-wasm-all.js",
    "wasm:build:debug": "pnpm exec node scripts/build-wasm-all.js --debug",
    "check:input": "bash apps/lights-out/scripts/check-input-controls.sh",
    "test:a11y": "pnpm exec playwright test --config=apps/lights-out/playwright.config.ts",
    "test:a11y:debug": "pnpm exec playwright test --config=apps/lights-out/playwright.config.ts --debug",
    "test:lighthouse": "pnpm exec node apps/lights-out/scripts/test-lighthouse.js",
    "test:a11y:ui": "pnpm test:lighthouse && pnpm test:a11y",
    "commit": "pnpm exec cz",
    "validate:matrix": "pnpm exec node scripts/validate-matrix.mjs",
    "generate-compliance-data": "pnpm exec node scripts/generate-compliance-data.mjs",
    "report:compliance": "pnpm generate-compliance-data && echo '✅ Compliance dashboard updated!'",
    "dashboard": "open compliance/dashboard.html || xdg-open compliance/dashboard.html || start compliance/dashboard.html",
    "dashboard:serve": "python3 -m http.server 8000 --directory .",
    "dashboard:build": "pnpm generate-compliance-data && pnpm dashboard:serve",
    "baseline:list": "echo '📊 WASM Performance Baselines:' && ls -lh compliance/baselines/*.json 2>/dev/null | awk '{print $9, \"(\" $5 \")\"}' || echo 'No historical baselines found' && echo '' && echo 'Active Baseline: compliance/wasm-profiles-baseline.json' && ls -lh compliance/wasm-profiles-baseline.json 2>/dev/null | awk '{print \"  Size: \" $5 \", Modified: \" $6 \" \" $7 \" \" $8}'",
    "baseline:show": "node -e \"const fs = require('fs'); try { const data = JSON.parse(fs.readFileSync('compliance/wasm-profiles-baseline.json', 'utf-8')); console.log(JSON.stringify(data.summary, null, 2)); } catch(e) { console.error('⚠️ Baseline file not found or invalid'); process.exit(1); }\"",
    "check:regressions": "echo '⏳ Regression detection (Phase 2): Script coming soon. For now, baselines are ready.' && echo '' && pnpm baseline:show",
    "monchola:web:build": "pnpm -C apps/monchola build"
    ,"monchola:web:dev": "pnpm -C apps/monchola dev"
    ,"monchola:web:preview": "pnpm -C apps/monchola preview"
    ,"monchola:web:lint": "pnpm -C apps/monchola lint"
    ,"monchola:web:format": "pnpm -C apps/monchola format"
    ,"monchola:web:typecheck": "pnpm -C apps/monchola typecheck"
    ,"monchola:web:test": "pnpm -C apps/monchola test"
    ,"monchola:web:check": "pnpm -C apps/monchola check"
    ,"monchola:web:fix": "pnpm -C apps/monchola fix"
    ,"monchola:web:validate": "pnpm -C apps/monchola validate"
    ,"monchola:web:clean": "pnpm -C apps/monchola clean"
    ,"monchola:android:build": "pnpm -C apps/monchola cap:sync"
    ,"monchola:android:dev": "pnpm -C apps/monchola cap:open:android"
    ,"monchola:android:run": "pnpm -C apps/monchola cap:run:android"
    ,"monchola:ios:build": "pnpm -C apps/monchola cap:sync"
    ,"monchola:ios:dev": "pnpm -C apps/monchola cap:open:ios"
    ,"monchola:ios:run": "pnpm -C apps/monchola cap:run:ios"
    ,"monchola:linux:build": "pnpm -C apps/monchola electron:build:linux"
    ,"monchola:linux:dev": "pnpm -C apps/monchola electron:dev"
    ,"monchola:linux:preview": "pnpm -C apps/monchola electron:preview"
    ,"monchola:windows:build": "pnpm -C apps/monchola electron:build:win"
    ,"monchola:mac:build": "pnpm -C apps/monchola electron:build:mac"
    ,"monchola:report:all": "pnpm -C apps/monchola report:all"
    ,"monchola:wasm:build": "pnpm -C apps/monchola wasm:build"
    ,"monchola:check:input": "pnpm -C apps/monchola check:input"
    ,"mancala:web:build": "pnpm -C apps/mancala build"
    ,"mancala:web:dev": "pnpm -C apps/mancala dev"
    ,"mancala:web:preview": "pnpm -C apps/mancala preview"
    ,"mancala:web:lint": "pnpm -C apps/mancala lint"
    ,"mancala:web:format": "pnpm -C apps/mancala format"
    ,"mancala:web:typecheck": "pnpm -C apps/mancala typecheck"
    ,"mancala:web:test": "pnpm -C apps/mancala test"
    ,"mancala:web:check": "pnpm -C apps/mancala check"
    ,"mancala:web:fix": "pnpm -C apps/mancala fix"
    ,"mancala:web:validate": "pnpm -C apps/mancala validate"
    ,"mancala:web:clean": "pnpm -C apps/mancala clean"
    ,"mancala:android:build": "pnpm -C apps/mancala cap:sync"
    ,"mancala:android:dev": "pnpm -C apps/mancala cap:open:android"
    ,"mancala:android:run": "pnpm -C apps/mancala cap:run:android"
    ,"mancala:ios:build": "pnpm -C apps/mancala cap:sync"
    ,"mancala:ios:dev": "pnpm -C apps/mancala cap:open:ios"
    ,"mancala:ios:run": "pnpm -C apps/mancala cap:run:ios"
    ,"mancala:linux:build": "pnpm -C apps/mancala electron:build:linux"
    ,"mancala:linux:dev": "pnpm -C apps/mancala electron:dev"
