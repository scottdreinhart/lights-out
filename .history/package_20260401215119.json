    ,"tictactoe:web:test": "pnpm -C apps/tictactoe test"
    ,"tictactoe:web:check": "pnpm -C apps/tictactoe check"
    ,"tictactoe:web:fix": "pnpm -C apps/tictactoe fix"
    ,"tictactoe:web:validate": "pnpm -C apps/tictactoe validate"
    ,"tictactoe:web:clean": "pnpm -C apps/tictactoe clean"
    ,"tictactoe:android:build": "pnpm -C apps/tictactoe cap:sync"
    ,"tictactoe:android:dev": "pnpm -C apps/tictactoe cap:open:android"
    ,"tictactoe:android:run": "pnpm -C apps/tictactoe cap:run:android"
    ,"tictactoe:ios:build": "pnpm -C apps/tictactoe cap:sync"
    ,"tictactoe:ios:dev": "pnpm -C apps/tictactoe cap:open:ios"
    ,"tictactoe:ios:run": "pnpm -C apps/tictactoe cap:run:ios"
