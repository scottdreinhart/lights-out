    ,"tictactoe:check:input": "pnpm -C apps/tictactoe check:input"
  },
  "dependencies": {
    "@games/theme-contract": "workspace:*",
    "@capacitor/core": "8.2.0",
    "clsx": "^2.1.1",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@capacitor/app": "8.1.0",
    "@capacitor/cli": "8.3.0",
    "@capacitor/keyboard": "8.0.2",
    "@capacitor/status-bar": "8.0.2",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.59.1",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "assemblyscript": "0.28.12",
    "commitizen": "^4.3.1",
    "concurrently": "9.2.1",
    "cz-conventional-changelog": "^3.3.0",
    "electron": "41.1.1",
    "electron-builder": "26.8.1",
    "eslint": "10.0.3",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-boundaries": "5.4.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-security": "^4.0.0",
    "kill-port": "2.0.1",
    "lighthouse": "13.0.3",
    "playwright": "1.59.1",
    "prettier": "3.8.1",
    "prettier-plugin-organize-imports": "4.3.0",
    "rimraf": "6.1.3",
    "rollup-plugin-visualizer": "5.14.0",
    "typescript": "6.0.2",
    "typescript-eslint": "8.58.0",
    "vite": "8.0.3",
    "wait-on": "9.0.4"
  },
  "pnpm": {
    "overrides": {
      "lodash": "4.17.23",
      "tmp": "0.2.4",
      "three": ">=0.125.0",
      "micromatch": ">=4.0.8"
    },
    "onlyBuiltDependencies": [
      "electron",
      "electron-winstaller",
      "esbuild"
    ]
  },
  "build": {
    "appId": "com.scottreinhart.lightsout",
    "productName": "Lights Out",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": [
        "portable"
      ],
      "signAndEditExecutable": false
    },
    "mac": {
      "target": [
        "dmg"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    }
  },
  "commitizen": {
    "path": "cz-conventional-changelog"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "src/**/*.css": [
      "prettier --write"
    ],
    "*.{json,md,js}": [
      "prettier --write"
    ]
  }
}
