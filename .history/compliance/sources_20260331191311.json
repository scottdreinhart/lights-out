        "allowedAPIs": ["Web APIs", "ServiceWorker"],
        "minBundleSize": "0",
        "maxBundleSize": "50MB",
        "performance": "load < 3s"
      },
      "touchSafe": true,
      "offlineCapable": false
    },
    "crazygames": {
      "title": "CrazyGames",
      "type": "web",
      "constraints": {
        "forbiddenAPIs": ["Node.js", "Electron"],
        "allowedAPIs": ["Web APIs", "CrazyGames SDK"],
        "minBundleSize": "0",
        "maxBundleSize": "50MB",
        "performance": "load < 3s"
      },
      "touchSafe": true,
      "offlineCapable": false
    },
    "discord": {
      "title": "Discord Activities",
      "type": "social",
      "constraints": {
        "forbiddenAPIs": ["Node.js", "Electron", "local filesystem"],
        "allowedAPIs": ["Discord SDK", "Web APIs"],
        "minBundleSize": "0",
        "maxBundleSize": "10MB",
        "performance": "load < 2s"
      },
      "touchSafe": true,
      "offlineCapable": false
    },
    "telegram": {
      "title": "Telegram Mini Apps",
      "type": "social",
      "constraints": {
        "forbiddenAPIs": ["Node.js", "Electron", "payments without Telegram SDK"],
        "allowedAPIs": ["Telegram Web Apps SDK", "Web APIs"],
        "minBundleSize": "0",
        "maxBundleSize": "8MB",
        "performance": "load < 2s"
      },
      "touchSafe": true,
      "offlineCapable": false
    },
    "steam": {
      "title": "Steam",
      "type": "desktop",
      "constraints": {
        "forbiddenAPIs": ["unsupported Chromium versions"],
        "allowedAPIs": ["Electron", "Node.js", "Steam API"],
        "minBundleSize": "0",
        "maxBundleSize": "500MB",
        "performance": "launch < 3s"
      },
      "touchSafe": false,
      "offlineCapable": true
    }
  },
  "validationRules": {
    "appExists": {
      "description": "App folder exists in /apps with entry point",
      "check": "folder exists && entry point present"
    },
    "rulesVerified": {
      "description": "Core rules match canonical source",
      "check": "rules in code match sources.json"
    },
    "platformAdapter": {
      "description": "Platform-specific adapter/entry point",
      "check": "platform entry present && no forbidden APIs"
    },
    "performanceCompliance": {
      "description": "Bundle size, load time, solve time within limits",
      "check": "metrics match platform constraints"
    },
    "uiCompliance": {
      "description": "Responsive, touch-safe, accessible",
      "check": "mobile breakpoints + touch handling + a11y"
    },
    "blockersFree": {
      "description": "No high-severity blockers",
      "check": "all high-severity issues resolved or mitigated"
    }
  }
}
