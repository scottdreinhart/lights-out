# SMTP Configuration for Regression Email Alerts
# ⚠️ THIS FILE CONTAINS SENSITIVE CREDENTIALS
# 
# SECURITY REQUIREMENTS:
# 1. Store actual credentials in .env.local (which is git-ignored)
# 2. Never commit this file with real passwords
# 3. Use app-specific passwords, not account passwords
# 4. Rotate credentials quarterly
# 5. Use strong, unique passwords

# Email Configuration
EMAIL_ENABLED=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=scottdreinhart@gmail.com
SMTP_PASS=your-16-character-app-password-here

# Email Recipients
NOTIFICATION_EMAIL=scottdreinhart@gmail.com
CC_EMAIL=

# SMS Configuration (Gmail Fi example)
SMS_EMAIL=4246664233@msg.fi.google.com

# Slack Configuration (optional)
SLACK_ENABLED=false
SLACK_WEBHOOK_URL=

# Dashboard URL
DASHBOARD_URL=http://localhost:3000/compliance/dashboard.html

# Testing (set to true to force notifications even without regressions)
SEND_ALL_NOTIFICATIONS=false
