#!/bin/sh
. "$(dirname "$0")/_/husky.sh"

# prepare-commit-msg hook - provides feedback on commit structure
# This is informational only and does not block commits

COMMIT_MSG_FILE=$1
COMMIT_SOURCE=$2

# Only process actual commits (not merges, squashes, etc)
if [ "$COMMIT_SOURCE" != "message" ] && [ "$COMMIT_SOURCE" != "template" ] && [ -n "$COMMIT_SOURCE" ]; then
  exit 0
fi

# Read the commit message
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")

# Check if message starts with emoji (from our gitmoji list)
if echo "$COMMIT_MSG" | grep -qE "^(✨|🐛|📚|💄|♻️|⚡|✅|🔨|🔄|🧹|⏮️|🔒|📦|💥)"; then
  # Looks good!
  exit 0
fi

# Check if it starts with conventional type
if echo "$COMMIT_MSG" | grep -qE "^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert|security|deps)"; then
  # Looks good!
  exit 0
fi

# If not, show a hint (but don't block)
if [ "$COMMIT_SOURCE" = "message" ] || [ "$COMMIT_SOURCE" = "" ]; then
  echo ""
  echo "💡 Tip: Use 'pnpm commit' for guided commit message with gitmoji!"
  echo "   Emojis: ✨ (feat), 🐛 (fix), 📚 (docs), ♻️ (refactor), ⚡ (perf), etc."
  echo ""
fi

exit 0
