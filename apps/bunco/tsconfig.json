{
  "compilerOptions": {
    "target": "ES2020",
    "lib": [
      "ES2020",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "types": [
      "vite/client"
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@/domain/*": [
        "./src/domain/*"
      ],
      "@/app/*": [
        "./src/app/*"
      ],
      "@/ui/*": [
        "./src/ui/*"
      ],
      "@games/domain-shared": [
        "../../packages/domain-shared/src"
      ],
      "@games/storage-utils": [
        "../../packages/storage-utils/src"
      ],
      "@games/sound-context": [
        "../../packages/sound-context/src"
      ],
      "@games/theme-context": [
        "../../packages/theme-context/src"
      ]
    }
  },
  "include": [
    "src",
    "src/vite-env.d.ts"
  ]
}
