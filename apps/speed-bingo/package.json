{
    "name": "@games/speed-bingo",
    "version": "1.0.0",
    "description": "Speed Bingo - Fast-Paced Bingo Action",
    "type": "module",
    "private": true,
    "license": "PROPRIETARY",
    "author": "Scott Reinhart",
    "packageManager": "pnpm@10.31.0",
    "engines": {
        "node": "24.14.1",
        "pnpm": "10.31.0"
    },
    "main": "electron/main.js",
    "scripts": {
        "start": "pnpm exec vite --host",
        "dev": "pnpm exec kill-port 5173 || true; pnpm exec vite --host",
        "build": "pnpm exec vite build",
        "preview": "pnpm exec vite preview",
        "build:preview": "pnpm build && pnpm preview",
        "lint": "pnpm exec eslint src/",
        "lint:fix": "pnpm exec eslint src/ --fix",
        "format": "pnpm exec prettier --write src/",
        "format:check": "pnpm exec prettier --check src/",
        "typecheck": "pnpm exec tsc",
        "check": "pnpm lint && pnpm format:check && pnpm typecheck",
        "fix": "pnpm lint:fix && pnpm format",
        "validate": "pnpm check && pnpm build",
        "clean": "pnpm exec rimraf dist release",
        "clean:node": "pnpm exec rimraf node_modules",
        "clean:all": "pnpm exec rimraf dist release node_modules"
    },
    "dependencies": {
        "react": "19.2.4",
        "react-dom": "19.2.4",
        "@games/domain-shared": "workspace:*",
        "@games/app-hook-utils": "workspace:*",
        "@games/assets-shared": "workspace:*",
        "@games/common": "workspace:*",
        "@games/storage-utils": "workspace:*",
        "@games/theme-context": "workspace:*",
        "@games/sound-context": "workspace:*",
        "@games/ui-utils": "workspace:*",
        "@games/ui-board-core": "workspace:*"
    },
    "devDependencies": {
        "@types/react": "19.2.14",
        "@types/react-dom": "19.2.3",
        "@vitejs/plugin-react": "^4.3.4",
        "eslint": "10.0.3",
        "eslint-plugin-boundaries": "1.1.0",
        "eslint-plugin-react": "7.37.2",
        "eslint-plugin-react-hooks": "5.0.0",
        "prettier": "3.8.1",
        "rimraf": "6.1.3",
        "typescript": "5.9.3",
        "typescript-eslint": "8.57.0",
        "vite": "^8.0.3",
        "vitest": "4.0.18"
    }
}