{
    "name": "@games/bingo-90",
    "version": "1.0.0",
    "description": "90-ball Bingo - Classic UK bingo variant with 90 numbers and multiple winning patterns",
    "private": true,
    "type": "module",
    "scripts": {
        "start": "vite",
        "dev": "vite",
        "build": "vite build",
        "preview": "vite preview",
        "lint": "eslint src --ext .ts,.tsx",
        "lint:fix": "eslint src --ext .ts,.tsx --fix",
        "typecheck": "tsc --noEmit",
        "test": "vitest",
        "test:watch": "vitest --watch",
        "electron:dev": "concurrently \"pnpm dev\" \"wait-on http://localhost:5173 && electron .\"",
        "electron:build": "vite build && electron-builder",
        "electron:build:win": "vite build && electron-builder --win",
        "electron:build:linux": "vite build && electron-builder --linux",
        "electron:build:mac": "vite build && electron-builder --mac",
        "cap:sync": "cap sync",
        "cap:init:android": "cap add android",
        "cap:init:ios": "cap add ios",
        "cap:open:android": "cap open android",
        "cap:open:ios": "cap open ios",
        "cap:run:android": "cap run android",
        "cap:run:ios": "cap run ios",
        "clean": "rimraf dist release",
        "clean:node": "rimraf node_modules",
        "clean:all": "pnpm clean && pnpm clean:node",
        "reinstall": "pnpm clean:node && pnpm install",
        "check": "pnpm lint && pnpm typecheck",
        "fix": "pnpm lint:fix",
        "validate": "pnpm check && pnpm build"
    },
    "dependencies": {
        "@games/bingo-core": "workspace:*",
        "@games/ui-board-core": "workspace:*",
        "react": "^19.2.4",
        "react-dom": "^19.2.4"
    },
    "devDependencies": {
        "@types/react": "^19.0.0",
        "@types/react-dom": "^19.0.0",
        "@vitejs/plugin-react": "^4.3.3",
        "electron": "^40.8.0",
        "electron-builder": "^26.8.1",
        "concurrently": "^9.2.1",
        "wait-on": "^8.0.1",
        "@capacitor/core": "^8.2.0",
        "@capacitor/android": "^8.2.0",
        "@capacitor/cli": "^8.2.0",
        "typescript": "^5.9.3",
        "vite": "^7.3.2",
        "vitest": "^4.0.18",
        "@testing-library/react": "^16.3.2",
        "@testing-library/jest-dom": "^6.6.4",
        "jsdom": "^26.0.0",
        "eslint": "^10.0.3",
        "@typescript-eslint/eslint-plugin": "^8.19.1",
        "@typescript-eslint/parser": "^8.19.1",
        "prettier": "^3.4.2",
        "rimraf": "^6.1.3"
    },
    "build": {
        "appId": "com.scottreinhart.bingo90",
        "productName": "Bingo 90",
        "directories": {
            "output": "release"
        },
        "files": [
            "dist/**/*",
            "electron/**/*"
        ],
        "mac": {
            "target": "dmg"
        },
        "win": {
            "target": "nsis"
        },
        "linux": {
            "target": "AppImage"
        }
    }
}