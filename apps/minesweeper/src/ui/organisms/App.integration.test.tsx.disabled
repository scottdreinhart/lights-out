import { describe, it, expect, vi, beforeEach } from 'vitest'
import { render, screen, waitFor } from '@testing-library/react'
import userEvent from '@testing-library/user-event'
import { App } from './App'

// Mock all child components to isolate integration testing
vi.mock('@/ui', () => ({
  GameBoard: () => <div data-testid="game-board">GameBoard Mock</div>,
  HamburgerMenu: ({ open, onRules, onHelp }: any) => (
    <aside data-testid="hamburger-menu" data-open={open}>
      {open && (
        <div data-testid="menu-items">
          <button onClick={onRules} data-testid="rules-btn">
            Rules
          </button>
          <button onClick={onHelp} data-testid="help-btn">
            Help
          </button>
        </div>
      )}
    </aside>
  ),
  Hud: () => <div data-testid="hud">HUD Mock</div>,
  LandingPage: ({ onStart }: any) => (
    <button onClick={onStart} data-testid="start-btn">
      Start
    </button>
  ),
  ScoresScreen: ({ onBack }: any) => (
    <button onClick={onBack} data-testid="back-btn">
      Back
    </button>
  ),
  SplashScreen: () => <div data-testid="splash">Splash Mock</div>,
}))

vi.mock('./modals', () => ({
  RulesModal: ({ isOpen, onClose }: any) =>
    isOpen ? (
      <div data-testid="rules-modal" role="dialog">
        <h2>Minesweeper Rules</h2>
        <button onClick={onClose}>Close</button>
      </div>
    ) : null,
  HelpModal: ({ isOpen, onClose }: any) =>
    isOpen ? (
      <div data-testid="help-modal" role="dialog">
        <h2>Minesweeper Help</h2>
        <button onClick={onClose}>Close</button>
      </div>
    ) : null,
}))

vi.mock('@/app', () => ({
  useGame: () => ({
    changeDifficulty: vi.fn(),
    chord: vi.fn(),
    difficulty: 'beginner',
    elapsedSeconds: 0,
    game: {
      board: [],
      cols: 9,
      rows: 9,
      mines: 10,
      flagsPlaced: 0,
      status: 'idle',
    },
    resetGame: vi.fn(),
    resetStats: vi.fn(),
    reveal: vi.fn(),
    submitBoard: vi.fn(),
    stats: { wins: 0, losses: 0, streak: 0, bestStreak: 0 },
    toggleCellFlag: vi.fn(),
  }),
  useSoundContext: () => ({
    click: vi.fn(),
    reveal: vi.fn(),
    explosion: vi.fn(),
    soundEnabled: true,
    toggleSound: vi.fn(),
    win: vi.fn(),
  }),
  useThemeContext: () => ({
    settings: {
      colorTheme: 'light',
      mode: 'normal',
      colorblind: 'none',
    },
    setColorTheme: vi.fn(),
    setColorblind: vi.fn(),
    setMode: vi.fn(),
  }),
  useKeyboardControls: vi.fn(),
  ensureWasmReady: vi.fn(),
  terminateAsyncAi: vi.fn(),
  computeAiMoveAsync: vi.fn(),
}))

describe('Minesweeper App Modal Integration', () => {
  beforeEach(() => {
    vi.clearAllMocks()
  })

  it('renders the app splash screen initially', async () => {
    render(<App />)
    expect(screen.getByTestId('splash')).toBeInTheDocument()
  })

  it('transitions to landing page after splash timeout', async () => {
    render(<App />)

    await waitFor(
      () => {
        expect(screen.getByTestId('start-btn')).toBeInTheDocument()
      },
      { timeout: 2000 },
    )
  })

  it('opens and closes RulesModal when Rules button is clicked', async () => {
    const user = userEvent.setup()
    render(<App />)

    // Switch to game screen
    await waitFor(() => expect(screen.getByTestId('start-btn')).toBeInTheDocument())
    await user.click(screen.getByTestId('start-btn'))

    // Rules modal should not be visible initially
    expect(screen.queryByTestId('rules-modal')).not.toBeInTheDocument()

    // Open menu
    const menuButton = screen.getByRole('button', { name: 'toggle-menu' })
    await user.click(menuButton)

    // Click Rules button
    const rulesBtn = screen.getByTestId('rules-btn')
    await user.click(rulesBtn)

    // Rules modal should now be visible
    await waitFor(() => {
      expect(screen.getByTestId('rules-modal')).toBeInTheDocument()
    })

    // Close modal
    const closeBtn = screen.getByRole('button', { name: 'Close' })
    await user.click(closeBtn)

    // Modal should be hidden
    await waitFor(() => {
      expect(screen.queryByTestId('rules-modal')).not.toBeInTheDocument()
    })
  })

  it('opens and closes HelpModal when Help button is clicked', async () => {
    const user = userEvent.setup()
    render(<App />)

    // Switch to game screen
    await waitFor(() => expect(screen.getByTestId('start-btn')).toBeInTheDocument())
    await user.click(screen.getByTestId('start-btn'))

    // Help modal should not be visible initially
    expect(screen.queryByTestId('help-modal')).not.toBeInTheDocument()

    // Open menu
    const menuButton = screen.getByRole('button', { name: 'toggle-menu' })
    await user.click(menuButton)

    // Click Help button
    const helpBtn = screen.getByTestId('help-btn')
    await user.click(helpBtn)

    // Help modal should now be visible
    await waitFor(() => {
      expect(screen.getByTestId('help-modal')).toBeInTheDocument()
    })

    // Close modal
    const closeBtn = screen.getAllByRole('button', { name: 'Close' })[1] // Second Close button (Help modal)
    await user.click(closeBtn)

    // Modal should be hidden
    await waitFor(() => {
      expect(screen.queryByTestId('help-modal')).not.toBeInTheDocument()
    })
  })

  it('keeps modals hidden when menu is closed', async () => {
    const user = userEvent.setup()
    render(<App />)

    // Switch to game screen
    await waitFor(() => expect(screen.getByTestId('start-btn')).toBeInTheDocument())
    await user.click(screen.getByTestId('start-btn'))

    // Both modals should be hidden
    expect(screen.queryByTestId('rules-modal')).not.toBeInTheDocument()
    expect(screen.queryByTestId('help-modal')).not.toBeInTheDocument()
  })

  it('supports modal accessibility: keyboard navigation', async () => {
    const user = userEvent.setup()
    render(<App />)

    // Switch to game screen
    await waitFor(() => expect(screen.getByTestId('start-btn')).toBeInTheDocument())
    await user.click(screen.getByTestId('start-btn'))

    // Open menu
    const menuButton = screen.getByRole('button', { name: 'toggle-menu' })
    await user.click(menuButton)

    // Click Rules button
    const rulesBtn = screen.getByTestId('rules-btn')
    await user.click(rulesBtn)

    // Modal should be visible with proper role
    const modal = await screen.findByTestId('rules-modal')
    expect(modal).toHaveAttribute('role', 'dialog')
  })

  it('renders both modals independently without interference', async () => {
    const user = userEvent.setup()
    render(<App />)

    // Switch to game screen
    await waitFor(() => expect(screen.getByTestId('start-btn')).toBeInTheDocument())
    await user.click(screen.getByTestId('start-btn'))

    // Open menu
    const menuButton = screen.getByRole('button', { name: 'toggle-menu' })
    await user.click(menuButton)

    // Open Rules modal
    const rulesBtn = screen.getByTestId('rules-btn')
    await user.click(rulesBtn)

    // Verify Rules modal is open
    await waitFor(() => {
      expect(screen.getByTestId('rules-modal')).toBeInTheDocument()
    })

    // Close Rules modal
    const closeBtns = screen.getAllByRole('button', { name: 'Close' })
    await user.click(closeBtns[0])

    // Verify Rules modal is closed
    await waitFor(() => {
      expect(screen.queryByTestId('rules-modal')).not.toBeInTheDocument()
    })

    // Open Help modal
    const helpBtn = screen.getByTestId('help-btn')
    await user.click(helpBtn)

    // Verify Help modal is open
    await waitFor(() => {
      expect(screen.getByTestId('help-modal')).toBeInTheDocument()
    })

    // Verify Rules modal is still closed
    expect(screen.queryByTestId('rules-modal')).not.toBeInTheDocument()
  })
})
