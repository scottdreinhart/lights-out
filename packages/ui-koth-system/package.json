{
    "name": "@games/ui-koth-system",
    "version": "1.0.0",
    "description": "Shared KotH (King of the Hill) ranking screen system for competitive games",
    "type": "module",
    "main": "./src/index.ts",
    "types": "./src/index.ts",
    "exports": {
        ".": {
            "import": "./src/index.ts",
            "types": "./src/index.ts"
        },
        "./types": {
            "import": "./src/types/index.ts",
            "types": "./src/types/index.ts"
        },
        "./components": {
            "import": "./src/components/index.ts",
            "types": "./src/components/index.ts"
        },
        "./hooks": {
            "import": "./src/hooks/index.ts",
            "types": "./src/hooks/index.ts"
        }
    },
    "scripts": {
        "typecheck": "tsc --noEmit",
        "lint": "eslint src/**/*.{ts,tsx}"
    },
    "files": [
        "src"
    ],
    "keywords": [
        "koth",
        "king-of-the-hill",
        "ranking",
        "leaderboard",
        "competitive",
        "ui",
        "games"
    ],
    "author": "Game Platform Team",
    "license": "MIT",
    "dependencies": {
        "react": "^19.2.4",
        "react-dom": "^19.2.4"
    },
    "peerDependencies": {
        "react": ">=19.0.0",
        "react-dom": ">=19.0.0"
    }
}