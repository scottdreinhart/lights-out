    "dev": "tsc --watch"
  },
  "dependencies": {
    "react": "^19.2.4"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "engines": {
    "node": ">=24.14.0",
    "pnpm": ">=10.31.0"
  }
}
