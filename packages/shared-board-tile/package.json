{
  "name": "@games/shared-board-tile",
  "version": "1.0.0",
  "description": "Shared grid cell component for board-based games (Battleship, Checkers, Bingo, Queens, Sudoku, etc.)",
  "type": "module",
  "main": "./dist/index.js",
