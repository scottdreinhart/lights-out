{
  "name": "@games/assets-shared",
  "version": "1.0.0",
  "description": "Shared hooks, components, and assets for all games",
  "type": "module",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./hooks": {
      "import": "./src/hooks/index.ts",
      "types": "./src/hooks/index.ts"
    },
    "./components": {
      "import": "./src/components/index.ts",
      "types": "./src/components/index.ts"
    },
    "./themes/*": "./src/themes/*"
  },
  "files": [
    "src"
  ],
  "scripts": {
    "build": "tsc"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "react": "^19.2.4"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "typescript": "5.9.3"
  }
}
