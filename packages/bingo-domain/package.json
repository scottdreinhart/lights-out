{
    "name": "@games/bingo-domain",
    "version": "1.0.0",
    "description": "Bingo game domain logic and rules - shared across variants",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "type": "module",
    "scripts": {
        "build": "tsc",
        "lint": "eslint src/",
        "lint:fix": "eslint src/ --fix",
        "format": "prettier --write src/",
        "format:check": "prettier --check src/",
        "typecheck": "tsc --noEmit",
        "check": "pnpm lint && pnpm format:check && pnpm typecheck",
        "validate": "pnpm check && pnpm build"
    },
    "dependencies": {},
    "devDependencies": {
        "@types/node": "^20.0.0",
        "typescript": "^5.0.0"
    }
}